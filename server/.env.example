# Server Environment Variables
# Copy this file to .env and fill in your values.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (local example)
DATABASE_URL="postgresql://postgres:password@localhost:5432/payment_app?schema=public"

# ─── Authentication ───────────────────────────────────────────────────────────
# Use a long, random string in production (e.g. openssl rand -hex 64)
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# sk_test_... for test mode, sk_live_... for production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ─── CORS ────────────────────────────────────────────────────────────────────
# Production frontend URL (leave empty for development — allows all origins)
CLIENT_URL=
