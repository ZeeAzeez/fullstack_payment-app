# Mobile Environment Variables
# Copy this file to .env and fill in your values.

# ─── API ─────────────────────────────────────────────────────────────────────
# Backend server URL used in production builds.
# In development, the app auto-selects localhost (iOS) or 10.0.2.2 (Android).
EXPO_PUBLIC_API_URL=https://your-production-api.example.com

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Publishable key from https://dashboard.stripe.com/apikeys
# pk_test_... for test mode, pk_live_... for production
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
